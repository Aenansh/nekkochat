generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Attachment {
  id           String         @id
  postUrl      String
  type         AttachmentType
  discussionId String?
  commentId    String?        @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  Comment      Comment?       @relation(fields: [commentId], references: [id], onDelete: Cascade)
  Discussion   Discussion?    @relation(fields: [discussionId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id           String      @id
  discussionId String?
  commentId    String?
  userId       String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime
  Comment      Comment?    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  Discussion   Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  User         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@unique([userId, discussionId])
}

model Category {
  id            String     @id
  name          String     @unique
  categoryOrder Int        @default(99)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime
  slug          String     @unique
  Category_A    Category[] @relation("CategoryDependencies")
  Category_B    Category[] @relation("CategoryDependencies")
  Question      Question[]

  @@index([categoryOrder])
}

model Comment {
  id            String      @id
  description   String
  authorId      String
  discussionId  String
  parentId      String?
  likeCount     Int         @default(0)
  dislikeCount  Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  Attachment    Attachment?
  Bookmark      Bookmark[]
  User          User        @relation(fields: [authorId], references: [id])
  Discussion    Discussion  @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  Comment       Comment?    @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_Comment Comment[]   @relation("CommentToComment")
  Like          Like[]
  Report        Report[]
}

model Company {
  id         String     @id
  name       String     @unique
  logo       String?    @unique
  websiteUrl String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime
  slug       String     @unique
  logoId     String?    @unique
  Question   Question[]
}

model Discussion {
  id           String       @id
  title        String
  description  String
  authorId     String
  likeCount    Int          @default(0)
  dislikeCount Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  tagId        String
  Attachment   Attachment[]
  Bookmark     Bookmark[]
  Comment      Comment[]
  User         User         @relation(fields: [authorId], references: [id])
  Tag          Tag          @relation(fields: [tagId], references: [id])
  Like         Like[]
  Report       Report[]
}

model Like {
  id           String      @id
  type         LikeType
  discussionId String?
  commentId    String?
  userId       String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime
  Comment      Comment?    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  Discussion   Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  User         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@unique([userId, discussionId])
}

model Question {
  id                  String         @id
  slug                String         @unique
  title               String
  description         String
  difficulty          Difficulty     @default(Medium)
  externalPlatformUrl String
  solutionUrl         String
  noOfSubmissions     Int            @default(0)
  noOfPeopleSolved    Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime
  Shelf               Shelf[]
  UserProgress        UserProgress[]
  Category            Category[]
  Company             Company[]
}

model Report {
  id                           String           @id
  reason                       String
  reporterId                   String
  discussionId                 String?
  commentId                    String?
  status                       ReportStatusType @default(PENDING)
  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime
  reportedId                   String?
  Comment                      Comment?         @relation(fields: [commentId], references: [id])
  Discussion                   Discussion?      @relation(fields: [discussionId], references: [id])
  User_Report_reportedIdToUser User?            @relation("Report_reportedIdToUser", fields: [reportedId], references: [id])
  User_Report_reporterIdToUser User             @relation("Report_reporterIdToUser", fields: [reporterId], references: [id])
}

model Shelf {
  id         String    @id
  type       ShelfType
  questionId String
  userId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  Question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
}

model SocialLink {
  id          String   @id
  platform    String
  platformUrl String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [userId], references: [id])

  @@unique([userId, platform])
}

model Tag {
  id         String       @id
  name       String       @unique
  slug       String       @unique
  color      String?      @default("blue")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  Discussion Discussion[]
}

model User {
  id                             String         @id
  email                          String         @unique
  name                           String?
  profileUrl                     String?
  firstName                      String?
  lastName                       String?
  bio                            String?
  isOnboarded                    Boolean?       @default(false)
  noOfQuestionsSolved            Int?           @default(0)
  beltRank                       BeltType       @default(white_belt)
  role                           String         @default("user")
  isShadowBanned                 Boolean        @default(false)
  isBanned                       Boolean        @default(false)
  createdAt                      DateTime       @default(now())
  updatedAt                      DateTime
  sudoPassword                   String?
  Bookmark                       Bookmark[]
  Comment                        Comment[]
  Discussion                     Discussion[]
  Like                           Like[]
  Report_Report_reportedIdToUser Report[]       @relation("Report_reportedIdToUser")
  Report_Report_reporterIdToUser Report[]       @relation("Report_reporterIdToUser")
  Shelf                          Shelf[]
  SocialLink                     SocialLink[]
  UserProgress                   UserProgress[]
}

model UserProgress {
  id         String             @id
  userId     String
  questionId String
  status     QuestionStatusType @default(unvisited)
  userCode   String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime
  Question   Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  User       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

enum AttachmentType {
  image
  video
  gif
}

enum BeltType {
  white_belt
  yellow_belt
  orange_belt
  green_belt
  blue_belt
  purple_belt
  brown_belt
  black_belt
}

enum Difficulty {
  Easy
  Hard
  Medium
}

enum LikeType {
  like
  dislike
}

enum QuestionStatusType {
  completed
  attempted
  unvisited
}

enum ReportStatusType {
  PENDING
  REVIEWED
  DISMISSED
}

enum ShelfType {
  later
  revisit
  stuck
  important
}

enum TagType {
  Discussion
  Senseis_Wisdom
  Guidance_Needed
  Kata
  Ronins_Path
  Dojo_Life
  Showcase
  Dynamic_Programming
  Graphs_n_Trees
  Arrays_n_Strings
  Recursion
  Bit_Manipulation
  System_Design
  Math_n_Geometry
  TypeScript_JavaScript
  Python
  CPP_n_C
  Java
  Rust
  Gate
  SQL
  NoSQL
  Frontend
  Backend
  Job
  Placement
}
